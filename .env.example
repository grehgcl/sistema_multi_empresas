# ============================================
# VARIÁVEIS DE AMBIENTE - SEE&AGENDE
# ============================================

# Servidor
PORT=3000
NODE_ENV=development

# JWT (JUST IN CASE)
JWT_SECRET=minha_chave_secreta_123

# Banco de Dados
# Para desenvolvimento local (SQLite) - não precisa configurar
# Para produção (PostgreSQL) - configure a URL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/barbearia

# Render
RENDER=false
RENDER_URL=http://localhost:3000

# Mercado Pago (opcional - para pagamentos reais)
MERCADO_PAGO_ACCESS_TOKEN=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxx
MERCADO_PAGO_PUBLIC_KEY=APP_USR-xxxx-xxxx-xxxx-xxxx

# Stripe (opcional)
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_PUBLIC_KEY=pk_live_xxxxxxxx

# Webhook
WEBHOOK_SECRET=seu_secret_aqui

# ============================================
# PARA PRODUÇÃO NO RENDER:
# ============================================
# RENDER=true
# NODE_ENV=production
# DATABASE_URL=postgresql://... (fornecido pelo Render)